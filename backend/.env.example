# The public name of the app
APP_NAME="Presenza AI - Prod"

# ── Security ─────────────────────────────────────
# Generate a secure key, e.g., with `openssl rand -hex 32`
SECRET_KEY=""
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="60"
REFRESH_TOKEN_EXPIRE_DAYS="7"

# ── CORS ─────────────────────────────────────────
# Put your frontend domains here separated by comma
ALLOWED_ORIGINS="https://your-frontend-domain.vercel.app,http://localhost:3000"

# ── Database (PostgreSQL/Supabase) ───────────────
DATABASE_URL="postgresql://user:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"

# ── Supabase Auth / Services (Optional) ──────────
SUPABASE_URL="https://yourproject.supabase.co"
SUPABASE_KEY="eyJ.........."

# ── Email (SMTP) ──────────────────────────────────
# Required for password resets / notifications
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAIL_FROM="your-email@gmail.com"
