FROM python:3.11-slim

# Install system dependencies required by OpenCV, DeepFace, and psycopg2
RUN apt-get update && apt-get install -y \
    libgl1-mesa-glx \
    libglib2.0-0 \
    gcc \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy and install dependencies first (Docker layer cache optimization)
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY . .

# Expose port (Render injects $PORT at runtime)
EXPOSE 8000

# Start the app — Render sets $PORT automatically
CMD sh -c "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"
